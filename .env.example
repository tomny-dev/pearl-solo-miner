# LuckyPool Pearl (PRL) miner configuration.
# Copy this file to .env and set PRL_WALLET:  cp .env.example .env

# ===== Required =====

# Your Pearl (PRL) payout address (starts with prl1...).
# Do NOT add a solo: prefix - SOLO_MODE handles that for you.
PRL_WALLET=

# ===== Common =====

# Worker label shown on the pool dashboard.
WORKER_NAME=rig01

# Mining mode: true = solo (lottery), false = shared pool (steady payouts).
SOLO_MODE=true

# Number of GPUs to use: 1, 2, or all.
GPU_COUNT=1

# Pool endpoint (LuckyPool North America, low-difficulty port for < 500 TH/s).
POOL_HOST=pearl-ca1.luckypool.io
POOL_PORT=3360

# ===== Advanced (optional - safe to leave as-is) =====

# Mine only on specific exposed GPUs, e.g. 0 or 0,1. Empty = all of them.
MINER_DEVICES=

# Extra raw arguments appended to the lpminer command line.
MINER_EXTRA_ARGS=

# Override the lpminer download (must be the LINUX .tar.gz build).
# Rebuild the image after changing this.
LPMINER_URL=https://pearl.luckypool.io/lpminer/lpminer-0.1.9.tar.gz

# SHA-256 of the archive above (build-time integrity check). If you change
# LPMINER_URL, set this to the new archive's hash (or empty to skip the check).
LPMINER_SHA256=2c7575b87a0ea95146bc83bf8c0729a7a9f551c64c5edfc2e51684e0ec78c196
