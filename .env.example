# LuckyPool Pearl (PRL) solo miner configuration.
# Copy this file to .env and fill in your values:  cp .env.example .env
# Nothing here is baked into the image - it is all read at runtime.

# ===== Required =====

# Your Pearl (PRL) payout wallet address (bech32m, starts with prl1...).
# Do NOT add the solo: prefix here - SOLO_MODE handles that for you.
PRL_WALLET=

# Short label for this rig/worker (letters, numbers and dashes).
WORKER_NAME=rig01

# ===== Pool endpoint =====
# Default is a LuckyPool North America server on the low-difficulty port,
# suitable for rigs under ~500 TH/s. Verify the current host/port on the
# pool's "Getting Started" page if connection fails.
#   3360 = low difficulty (~2M)   <- default, best for < 500 TH/s
#   3361 = medium difficulty (~4M)
#   3362 = high difficulty (~8M)
POOL_HOST=pearl-ca1.luckypool.io
POOL_PORT=3360

# ===== Solo mining =====
# true  -> wallet is prefixed with solo: (you win whole blocks, lottery-style)
# false -> normal shared pool mining (steady, proportional rewards)
SOLO_MODE=true

# ===== GPU selection =====
# Physical GPU index to mine on. 0 = first card, 1 = second card.
GPU_ID=0

# ===== Optional =====

# Stratum password field. LuckyPool accepts x.
MINER_PASSWORD=x

# Extra raw arguments appended to the lpminer command line, if you need them.
MINER_EXTRA_ARGS=

# lpminer download URL used at build time. Change to pin a different version.
LPMINER_URL=https://pearl.luckypool.io/lpminer/lpminer-0.1.9.tar.gz
